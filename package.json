{
  "name": "stream-flix",
  "private": true,
  "version": "1.0.0",
  "description": "Stream-Flix - Video streaming with watch together functionality",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:be": "cd backend && bun install ",
    "install:fe": "cd frontend && bun install",
    "dev:be": "cd backend && bun run dev",
    "dev:fe": "cd frontend && bun run dev",
    "build:frontend": "vite build",
    "build:backend": "npm run build --workspace=backend",
    "docker:build": "docker build -t stream-flix:latest .",
    "docker:up": "docker-compose --profile prod up -d",
    "docker:down": "docker-compose --profile prod down",
    "docker:dev": "docker-compose --profile dev up -d"
  }

}
